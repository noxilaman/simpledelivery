generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MERCHANT
  ADMIN
}

enum ShopApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  pending
  submitted
  verified
  rejected
}

enum OrderStatus {
  pending_payment
  payment_submitted
  payment_verified
  accepted
  cooking
  ready_to_deliver
  delivering
  completed
  cancelled
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(MERCHANT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop Shop?
}

model Shop {
  id              String   @id @default(cuid())
  ownerId         String   @unique
  name            String
  slug            String   @unique
  phone           String
  promptpayId     String
  bankAccountName String
  address         String   @db.Text
  deliveryFee     Decimal  @default(20.00) @db.Decimal(10, 2)
  deliveryNote    String?  @db.Text
  logoUrl         String?
  isOpen          Boolean  @default(true)
  approvalStatus  ShopApprovalStatus @default(PENDING)
  approvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner  User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  menus  Menu[]
  orders Order[]
  schedules ShopDaySchedule[]
  members CustomerMember[]
}

model ShopDaySchedule {
  id        String   @id @default(cuid())
  shopId    String
  date      DateTime @db.Date
  openTime  String   @default("09:00")
  closeTime String   @default("18:00")
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, date])
  @@index([shopId, date])
}

model Menu {
  id            String   @id @default(cuid())
  shopId        String
  name          String
  description   String   @db.Text
  price         Decimal  @db.Decimal(10, 2)
  imageUrl      String?
  availableDate DateTime @db.Date
  stockQty      Int      @default(0)
  soldQty       Int      @default(0)
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop       Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([shopId, availableDate, isAvailable])
}

model Order {
  id              String        @id @default(cuid())
  shopId          String
  memberId        String?
  orderCode       String        @unique
  trackingToken   String        @unique
  customerName    String
  customerPhone   String
  deliveryAddress String        @db.Text
  deliveryNote    String?       @db.Text
  subtotal        Decimal       @db.Decimal(10, 2)
  deliveryFee     Decimal       @db.Decimal(10, 2)
  totalPrice      Decimal       @db.Decimal(10, 2)
  paymentStatus   PaymentStatus @default(pending)
  orderStatus     OrderStatus   @default(pending_payment)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  shop       Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  member     CustomerMember?   @relation(fields: [memberId], references: [id], onDelete: SetNull)
  items      OrderItem[]
  payment    Payment?
  statusLogs OrderStatusLog[]

  @@index([shopId, createdAt])
  @@index([memberId, createdAt])
  @@index([trackingToken])
}

model CustomerMember {
  id              String   @id @default(cuid())
  shopId          String
  name            String
  phone           String
  passwordHash    String
  deliveryAddress String   @db.Text
  deliveryNote    String?  @db.Text
  acceptedTermsAt DateTime
  acceptedPdpaAt  DateTime
  totalOrders     Int      @default(0)
  totalSpent      Decimal  @default(0.00) @db.Decimal(10, 2)
  lastOrderedAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shop   Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orders Order[]

  @@unique([shopId, phone])
  @@index([shopId, updatedAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  menuId    String
  menuName  String
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  note      String?  @db.Text
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menu  Menu  @relation(fields: [menuId], references: [id])
}

model Payment {
  id           String        @id @default(cuid())
  orderId      String        @unique
  amount       Decimal       @db.Decimal(10, 2)
  slipImageUrl String?
  status       PaymentStatus @default(pending)
  verifiedAt   DateTime?
  createdAt    DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderStatusLog {
  id        String       @id @default(cuid())
  orderId   String
  oldStatus OrderStatus?
  newStatus OrderStatus
  note      String?      @db.Text
  createdAt DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}
